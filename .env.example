# mesh-memory configuration
# Copy to .env and fill in your values.

# ── LLM Provider (REQUIRED) ─────────────────────────────────
# How the server classifies incoming writes.
#
# "qwen"  — DashScope / OpenAI-compatible (see DASHSCOPE_BASE_URL).
#           writeMemory/writeMemoryAsync run the classifier; the agent
#           sends raw notes and the server decides kind/lane/anchors.
# "none"  — agent-as-gate mode. The server has no classifier; only
#           writeMemoryDirect is available. Use when the calling agent
#           (e.g. Claude Code) already decides kind/lane/anchors via a
#           slash command or skill. No API key required.
# "mock"  — DO NOT USE for real teams. Dummy classifications only;
#           exists for mesh-memory's own development.
LLM_PROVIDER=qwen

# Model for the write classifier.
#   DashScope:  qwen-plus, qwen-turbo, qwen-max, qwen3.5-flash
#   OpenAI:     gpt-4o-mini, gpt-4o
#   Ollama:     llama3, mistral, qwen2.5
LLM_MODEL=qwen-plus

# API key (required when LLM_PROVIDER=qwen)
DASHSCOPE_API_KEY=

# Base URL — override to use a different OpenAI-compatible provider:
#   DashScope (default):  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   OpenAI:               https://api.openai.com/v1
#   Ollama:               http://host.docker.internal:11434/v1
# DASHSCOPE_BASE_URL=

# ── Ports ────────────────────────────────────────────────────
# MESH_PORT=9080
# PG_PORT=5444

# ── Database ─────────────────────────────────────────────────
# POSTGRES_PASSWORD=mesh

# ── Logging ──────────────────────────────────────────────────
# RUST_LOG=info
